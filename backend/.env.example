PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/cleaning_tracker
JWT_SECRET=change_this_to_a_long_random_secret

# Gmail SMTP — REQUIRED for OTP emails to reach real inboxes
# 1. Enable 2-Step Verification on your Google account
# 2. Create App Password: https://myaccount.google.com/apppasswords
# 3. Paste the 16-character password below (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM_NAME=CleanTrack
SMTP_FROM_EMAIL=your.email@gmail.com

# Option B — Resend (easier, free at https://resend.com)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=CleanTrack <onboarding@resend.dev>

OTP_EXPIRY_MINUTES=5
OTP_RESEND_LIMIT_PER_HOUR=5
